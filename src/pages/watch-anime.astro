---
import Layout from '../layouts/Layout.astro';
import ListPageLayout from '../components/ListPageLayout.astro';
import PlacesSection, {
  type Place,
} from '../components/PlacesSection.astro';

// 今期視聴アニメのリスト
// 例:
// { label: 'アニメタイトル', href: 'https://example.com' }
const thisSeasonAnimes: Place[] = [
  { label: 'ようこそ実力至上主義の教室へ ', href: '' },
];
---

<Layout 
  title="今期視聴アニメ - @tonosaki"
  description="今期視聴しているアニメのメモです。タイトルをクリックすると各作品の公式サイトなどに飛べるようにしておきます。"
>
  <ListPageLayout
    title="今期視聴アニメ"
    backHref="/"
    backLabel="← ホームに戻る"
    description="今期視聴しているアニメのメモです。タイトルをクリックすると各作品の公式サイトなどに飛べるようにしておきます。"
  >
    <PlacesSection
      sectionId="this-season-anime-heading"
      title="今期視聴アニメ一覧"
      class="mt-10 mb-10"
      areas={
      [
        {
          id: '2026-winter-anime',
          title: '2026年冬アニメ',
          places: thisSeasonAnimes,
        },
      ]}
    />
  </ListPageLayout>
</Layout>


